---
import { primaryContactEmail, primaryContactHref } from '../config/contact';
import { launchRoutes } from '../config/navigation';
import BaseLayout from '../layouts/BaseLayout.astro';
import { launchPageMetadata } from '../lib/seo/site-metadata';

const metadata = launchPageMetadata.contact;
---

<BaseLayout metadata={metadata}>
  <main id="main-content" class="route-page">
    <section class="route-shell editorial-reveal">
      <div class="route-shell-accent">
        <p class="route-eyebrow">Contact</p>
        <p class="route-kicker">Direct outreach</p>
      </div>
      <h1>Reach out directly.</h1>
      <p class="route-intro route-lede">
        Email is the fastest way to reach me. Use it when you want to discuss a role, a team, consulting work, or a product problem that needs
        calm technical execution.
      </p>
      <ul class="route-meta" aria-label="Contact page context">
        <li>Use one direct email path instead of guessing between channels</li>
        <li>Know what to include so the reply can start in the right place</li>
        <li>Keep a plain-text fallback visible if your mail app does not open</li>
      </ul>
      <div class="resume-action-grid" aria-label="Contact actions">
        <a class="project-card-link" href={primaryContactHref}>Email Chris</a>
        <a class="project-card-link project-card-link-secondary" href={launchRoutes.resume}>Review the resume again</a>
      </div>
      <p class="route-intro">
        Send the role, team, project, or consulting context you have in mind, along with any timing that matters, so I can reply with the right
        scope and next step.
      </p>

      <section class="resume-fallback-box contact-recovery-box" aria-labelledby="contact-recovery-heading">
        <h2 class="resume-fallback-title" id="contact-recovery-heading">If email does not open</h2>
        <p class="resume-fallback-copy">
          If the email button does not open your mail app, use the address shown here and send your note from any client you prefer.
        </p>
        <ul class="contact-guidance-list" aria-label="Email fallback guidance">
          <li class="contact-guidance-card">
            <h3>What happens next</h3>
            <p>
              Selecting <strong>Email Chris</strong> should open your default mail app with a new message addressed to Chris. Add the role,
              team, project, or consulting context there and send when ready.
            </p>
          </li>
          <li class="contact-guidance-card">
            <h3>If your mail app does not open</h3>
            <p>
              Nothing is wrong with your outreach. Copy the email address shown here into any mail app you prefer and include the same context.
            </p>
          </li>
          <li class="contact-guidance-card">
            <h3>Need more context first?</h3>
            <p>
              If email is not the next step yet, review the resume again or go back to projects. Contact stays available when you are ready.
            </p>
          </li>
        </ul>
      </section>

      <ul class="contact-guidance-list" aria-label="How to reach out clearly">
        <li class="contact-guidance-card">
          <h2>What to send</h2>
          <p>Include the role, project brief, or consulting context so the conversation can start with the right scope.</p>
        </li>
        <li class="contact-guidance-card">
          <h2>What helps most</h2>
          <p>Mention timing, team shape, or the decision you are trying to make if you want the reply to be sharper and faster.</p>
        </li>
      </ul>

      <section class="resume-fallback-box contact-direct-box" aria-label="Direct contact details">
        <p class="resume-fallback-title">Use the email address shown here if your mail app stays closed.</p>
        <p class="resume-fallback-copy">
          The plain-text address below stays visible so you always have a direct fallback. You can copy it into any mail app you prefer.
        </p>
        <p class="contact-direct-line">
          <span class="contact-direct-label">Direct email</span>
          <code class="contact-direct-address">{primaryContactEmail}</code>
        </p>
      </section>

      <nav class="project-detail-actions" aria-label="Contact page next steps">
        <a class="project-card-link project-card-link-secondary" href={launchRoutes.projects}>Back to projects</a>
        <a class="project-card-link project-card-link-secondary" href={launchRoutes.resume}>Review the resume again</a>
      </nav>
    </section>
  </main>
</BaseLayout>
