---
import { primaryContactEmail, primaryContactHref } from '../config/contact';
import BaseLayout from '../layouts/BaseLayout.astro';
import { launchPageMetadata } from '../lib/seo/site-metadata';

const metadata = launchPageMetadata.contact;
---

<BaseLayout metadata={metadata}>
  <main id="main-content" class="route-page contact-page">
    <section class="route-shell editorial-reveal">
      <p class="route-eyebrow">Contact</p>
      <h1>Contact</h1>
      <p class="route-intro route-lede">Send me a note about a role, project, or consulting opportunity.</p>

      <form class="contact-form" id="contact-form">
        <label class="contact-field">
          <span>Your email <span class="optional-label">optional</span></span>
          <input class="contact-input" id="contact-email" name="email" type="email" autocomplete="email" />
        </label>
        <label class="contact-field">
          <span>Subject</span>
          <input class="contact-input" id="contact-subject" name="subject" required type="text" />
        </label>
        <label class="contact-field">
          <span>Message</span>
          <textarea class="contact-textarea" id="contact-message" name="message" required rows="8"></textarea>
        </label>
        <button class="project-card-link" type="submit">Open email draft</button>
      </form>

      <p class="contact-fallback">
        Email fallback: <a href={primaryContactHref}>{primaryContactEmail}</a>
      </p>

      <noscript>
        <p class="contact-fallback">JavaScript is disabled. Use the fallback email address above, or open a <a href={primaryContactHref}>direct email link</a>.</p>
      </noscript>
    </section>
  </main>

  <script define:vars={{ primaryContactEmail }}>
    const form = document.getElementById('contact-form');

    form?.addEventListener('submit', (event) => {
      event.preventDefault();

      const email = document.getElementById('contact-email')?.value.trim();
      const subject = document.getElementById('contact-subject')?.value.trim();
      const message = document.getElementById('contact-message')?.value.trim();

      if (!subject || !message) {
        form.reportValidity();
        return;
      }

      const body = email ? `${message}\n\nSender email: ${email}` : message;
      window.location.href = `mailto:${primaryContactEmail}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    });
  </script>
</BaseLayout>
