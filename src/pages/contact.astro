---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | Chris Fahey"
  description="A calm contact entry point that tells visitors how outreach will fit into the site without introducing the later contact workflow yet."
>
  <main class="route-page">
    <section class="route-shell">
      <p class="route-eyebrow">Contact</p>
      <h1>Clear outreach paths, without friction.</h1>
      <p class="route-intro">
        This page establishes a trustworthy destination for professional outreach and future contact options. It keeps scope intentionally light for
        now while making the site feel complete enough to navigate with confidence.
      </p>
    </section>
  </main>
</BaseLayout>
