---
import { getEntry, render } from 'astro:content';

import JourneyNextStep from '../components/journey/JourneyNextStep.astro';
import { launchRoutes } from '../config/navigation';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import SocialProofSection from '../components/sections/SocialProofSection.astro';

const homePage = await getEntry('pages', 'home');

if (!homePage) {
  throw new Error('Missing home page content entry.');
}

const { Content } = await render(homePage);

const {
  title,
  description,
  heroName,
  heroRole,
  heroIntro,
  trustTags,
  primaryCtaLabel,
  primaryCtaHref,
  portraitSrc,
  portraitAlt,
} = homePage.data;
---

<BaseLayout title={title} description={description}>
  <main id="main-content" class="home-page">
    <HeroSection
      heroName={heroName}
      heroRole={heroRole}
      heroIntro={heroIntro}
      trustTags={trustTags}
      primaryCtaLabel={primaryCtaLabel}
      primaryCtaHref={primaryCtaHref}
      portraitSrc={portraitSrc}
      portraitAlt={portraitAlt}
    />
    <SocialProofSection sectionId="proof" title="Selected proof points">
      <Content />
    </SocialProofSection>
    <JourneyNextStep
      ariaLabel="Homepage next steps"
      title="Continue from first impression into proof, resume, or direct outreach."
      intro="Use the same evaluation handoff pattern across the site: move into project proof for delivery detail, open the resume for formal experience, or go straight to contact when you already have enough signal to start a conversation."
      actions={[
        { href: launchRoutes.projects, label: 'Review project proof' },
        { href: launchRoutes.resume, label: 'Open the resume', variant: 'secondary' },
        { href: launchRoutes.contact, label: 'Start a conversation', variant: 'secondary' },
      ]}
    />
  </main>
</BaseLayout>
