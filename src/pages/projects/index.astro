---
import JourneyNextStep from '../../components/journey/JourneyNextStep.astro';
import ProjectIndexList from '../../components/projects/ProjectIndexList.astro';
import { launchRoutes } from '../../config/navigation';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjects } from '../../lib/content/get-projects';
import { launchPageMetadata } from '../../lib/seo/site-metadata';

const projects = await getProjects();
const metadata = launchPageMetadata.projects;
---

<BaseLayout metadata={metadata}>
  <main id="main-content" class="route-page projects-page">
    <section class="route-shell editorial-reveal">
      <div class="route-shell-accent">
        <p class="route-eyebrow">Projects</p>
        <p class="route-kicker">Selected work</p>
      </div>
      <h1>Selected projects, written for quick review.</h1>
      <p class="route-intro route-lede">
        Scan the work by context, role, and outcome. Each summary helps hiring teams see why it matters and open the most relevant project next.
      </p>
      <ul class="route-meta" aria-label="Projects page context">
        <li>Consistent summary structure supports side-by-side comparison under time pressure</li>
        <li>Each project opens on a normal detail page with standard browser navigation</li>
        <li>The surrounding navigation keeps resume and contact pathways visible throughout the review</li>
      </ul>
    </section>

    <section class="projects-comparison-shell editorial-reveal" aria-labelledby="projects-comparison-heading">
      <div class="projects-section-heading">
        <p class="route-eyebrow">Comparison</p>
        <h2 id="projects-comparison-heading">Choose the project that best matches the conversation.</h2>
        <p class="route-intro">
          Start with the project that feels most relevant, then continue to the resume from the next step below if you want the formal
          experience behind the work.
        </p>
      </div>

      <ProjectIndexList projects={projects} />
    </section>

    <JourneyNextStep
      ariaLabel="Projects index next steps"
      title="Continue to the resume when you want the formal experience."
       intro="If the index already gives you enough confidence, the resume is the next clear stop for role history, scope, and the concise professional record behind these projects."
      actions={[
        { href: launchRoutes.resume, label: 'Continue to the resume' },
        { href: launchRoutes.contact, label: 'Start a conversation', variant: 'secondary' },
      ]}
    />
  </main>
</BaseLayout>
