---
import { launchRoutes } from '../config/navigation';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getResumePageContent } from '../lib/content/get-resume';

const resumePage = await getResumePageContent();
---

<BaseLayout metadata={resumePage.metadata}>
  <main id="main-content" class="route-page resume-page">
    <section class="route-shell editorial-reveal">
      <h1>{resumePage.heading}</h1>

      {
        resumePage.actions.assetPath ? (
          <figure class="resume-preview-stack" aria-label="Resume preview">
            <div class="resume-preview-page resume-preview-page-first">
              <img
                class="resume-preview-image"
                src="/resume/chris-resume-page-1.png"
                alt="Resume page 1"
                width="1224"
                height="1584"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="resume-preview-page resume-preview-page-second">
              <img
                class="resume-preview-image"
                src="/resume/chris-resume-page-2.png"
                alt="Resume page 2"
                width="1224"
                height="1584"
                loading="lazy"
                decoding="async"
              />
            </div>
          </figure>
        ) : null
      }

      <p class="route-intro route-lede">{resumePage.intro}</p>

      {
        resumePage.actions.assetPath ? (
          <div class="resume-action-grid" aria-label="Resume actions">
            <a class="project-card-link" href={resumePage.actions.assetPath}>{resumePage.actions.viewLabel}</a>
            <a class="project-card-link project-card-link-secondary" download={resumePage.actions.downloadName} href={resumePage.actions.assetPath}>
              {resumePage.actions.downloadLabel}
            </a>
          </div>
        ) : (
          <div class="resume-fallback-box" aria-label="Resume fallback guidance">
            <p class="resume-fallback-copy">{resumePage.fallbackCopy}</p>
            <a class="project-card-link project-card-link-secondary" href={launchRoutes.contact}>Contact me</a>
          </div>
        )
      }
    </section>
  </main>
</BaseLayout>
