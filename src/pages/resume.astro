---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Resume | Chris Fahey"
  description="An orientation-forward resume entry point that explains what this section covers before deeper experience detail arrives."
>
  <main id="main-content" class="route-page">
    <section class="route-shell">
      <p class="route-eyebrow">Resume</p>
      <h1>Experience and scope, framed for evaluators.</h1>
      <p class="route-intro">
        Use this page to scan experience highlights, understand delivery scope, and move into the full resume with context already established.
        The goal is fast orientation for hiring teams without forcing them to leave the broader evaluation flow.
      </p>
    </section>
  </main>
</BaseLayout>
