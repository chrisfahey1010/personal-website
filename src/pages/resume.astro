---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Resume | Chris Fahey"
  description="An orientation-forward resume entry point that explains what this section covers before deeper experience detail arrives."
>
  <main class="route-page">
    <section class="route-shell">
      <p class="route-eyebrow">Resume</p>
      <h1>Experience and scope, framed for evaluators.</h1>
      <p class="route-intro">
        This route gives hiring teams a clear path to resume depth without turning Story 1.4 into a full resume build-out. It signals what kind of
        experience summary will appear here and how it supports the broader evaluation journey.
      </p>
    </section>
  </main>
</BaseLayout>
