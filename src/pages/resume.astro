---
import BaseLayout from '../layouts/BaseLayout.astro';
import { launchRoutes } from '../config/navigation';
import type { ResumeHighlight } from '../lib/content/get-resume';
import { getResumeAssetPath, getResumeHighlights, getResumeStatus } from '../lib/content/get-resume';
import { createPageMetadata } from '../lib/seo/get-page-metadata';
import { launchPageMetadata } from '../lib/seo/site-metadata';

const resumeDownloadName = 'Chris-Fahey-Resume.pdf';
const resumeStatus = getResumeStatus();
const hasResumeAsset = resumeStatus.isAvailable;
const resumeAssetPath = hasResumeAsset ? getResumeAssetPath() : undefined;
const resumeHighlights: ResumeHighlight[] = getResumeHighlights();
const pageDescription = hasResumeAsset
  ? 'A resume entry point that lets evaluators open or download a current PDF without losing orientation across projects and contact.'
  : 'A resume entry point that keeps evaluators oriented with a summary and recovery path while the canonical PDF is unavailable.';
const resumePrimaryIntro = hasResumeAsset
  ? 'Open the current resume PDF or download a copy with normal link behavior. This page frames what you will get first, then keeps visible paths back to project proof and forward to contact.'
  : 'The canonical resume PDF is unavailable right now, but this page still keeps the evaluation flow intact with a summary here and clear paths back to projects or forward to contact.';
const resumeSecondaryIntro = hasResumeAsset
  ? 'The PDF reflects current experience, recent product-engineering work, and the formal timeline behind the proof already shown on the site.'
  : `While the PDF is unavailable, this summary still gives evaluators the key context and a clear recovery path for requesting the latest copy. The resume source was last refreshed on ${resumeStatus.lastUpdated}.`;
const resumeMetaItems = hasResumeAsset
  ? [
      'Clear resume actions live in the static asset boundary and do not rely on hidden interaction',
      'The PDF is framed as current professional material before you open it',
      'Projects and contact stay visible so resume review feels like a continuation, not a dead end',
    ]
  : [
      'This route keeps the evaluation path alive when the canonical PDF is missing, stale, or being replaced',
      'The summary and contact recovery path stay visible instead of sending evaluators into a broken asset dead end',
      'Projects and contact remain close at hand so orientation is preserved across the handoff',
    ];
const resumeSummaryIntro = hasResumeAsset
  ? 'Use the PDF when you want the complete professional record. Use the surrounding links when you want deeper examples or a direct follow-up instead of guessing what comes next.'
  : 'Use this summary when you need the core professional context right now. Use the surrounding links when you want deeper examples or the latest resume copy without guessing what comes next.';
const metadata = createPageMetadata({
  title: launchPageMetadata.resume.title,
  description: pageDescription,
  canonicalPath: launchPageMetadata.resume.canonicalPath,
});
---

<BaseLayout metadata={metadata}>
  <main id="main-content" class="route-page resume-page">
    <section class="route-shell editorial-reveal">
      <div class="route-shell-accent">
        <p class="route-eyebrow">Resume</p>
        <p class="route-kicker">Evaluation handoff</p>
      </div>
      <h1>Review the resume without losing the thread of evaluation.</h1>
      <p class="route-intro route-lede">{resumePrimaryIntro}</p>
      <ul class="route-meta" aria-label="Resume page context">
        {resumeMetaItems.map((item) => <li>{item}</li>)}
      </ul>

      {
        hasResumeAsset ? (
          <div class="resume-action-grid" aria-label="Resume actions">
            <a class="project-card-link" href={resumeAssetPath}>
              View resume
            </a>
            <a class="project-card-link project-card-link-secondary" download={resumeDownloadName} href={resumeAssetPath}>
              Download PDF
            </a>
          </div>
        ) : (
          <div class="resume-fallback-box" aria-label="Resume fallback guidance">
            <p class="resume-fallback-title">Resume PDF unavailable right now</p>
            <p class="resume-fallback-copy">
              The direct PDF link is unavailable because the canonical asset is missing, stale, or being replaced. You can still review the
              summary below and use the contact path for the latest copy or a guided walkthrough.
            </p>
          </div>
        )
      }

      <p class="route-intro">{resumeSecondaryIntro}</p>
    </section>

    <section class="proof-shell editorial-reveal resume-summary-shell" aria-labelledby="resume-summary-heading">
      <div class="projects-section-heading">
        <p class="route-eyebrow">Resume summary</p>
        <h2 id="resume-summary-heading">A calm handoff from proof to formal experience.</h2>
        <p class="route-intro">
          {resumeSummaryIntro}
        </p>
      </div>

      <ul class="resume-summary-list" aria-label="Resume review guidance">
        {
          resumeHighlights.map((highlight) => (
            <li class="resume-summary-item">
              <h3>{highlight.title}</h3>
              <p>{highlight.description}</p>
            </li>
          ))
        }
      </ul>

      <p class="resume-fallback">
        If the PDF is unavailable or needs an update, use the contact path and I will send the latest copy directly with any context that
        helps your review.
      </p>

      <p class="resume-next-step-copy">
        When you are ready to turn project proof and formal experience into an actual conversation, continue to contact for the cleanest
        final handoff.
      </p>

      <nav class="project-detail-actions" aria-label="Resume page next steps">
        <a class="project-card-link project-card-link-secondary" href={launchRoutes.projects}>Back to projects</a>
        <a class="project-card-link project-card-link-secondary" href={launchRoutes.contact}>Continue to contact</a>
      </nav>
    </section>
  </main>
</BaseLayout>
