---
interface Props {
  heroName: string;
  heroRole: string;
  heroIntro: string;
  trustTags: string[];
  primaryCtaLabel: string;
  primaryCtaHref: string;
  portraitSrc?: string;
  portraitAlt?: string;
}

const {
  heroName,
  heroRole,
  heroIntro,
  trustTags,
  primaryCtaLabel,
  primaryCtaHref,
  portraitSrc,
  portraitAlt,
} = Astro.props;
---

<section class="hero-section editorial-reveal" aria-labelledby="hero-title">
  <div class="hero-copy">
    <div class="hero-context">
      <p class="hero-eyebrow">Warm editorial portfolio</p>
      <p class="hero-kicker">Designed to help evaluators form trust quickly, without template noise.</p>
    </div>
    <h1 id="hero-title">{heroName}</h1>
    <p class="hero-role">{heroRole}</p>
    <p class="hero-intro">{heroIntro}</p>

    <ul class="hero-credibility-list" aria-label="Professional context">
      <li>Product engineering shaped for senior IC and staff-level evaluation</li>
      <li>Content, UX, and implementation decisions carried through one authored system</li>
      <li>Calm delivery signals that stay legible under skim-heavy review</li>
    </ul>

    <div class="hero-actions">
      <a class="hero-cta" href={primaryCtaHref}>{primaryCtaLabel}</a>

      <ul class="trust-tags" aria-label="Trust signals">
        {trustTags.map((tag) => <li>{tag}</li>)}
      </ul>
    </div>
  </div>

  <aside class="hero-signal" aria-label="Professional signal">
    <div class="hero-signal-media">
      {
        portraitSrc && portraitAlt ? (
          <img class="hero-portrait" src={portraitSrc} alt={portraitAlt} width="320" height="400" loading="eager" />
        ) : (
          <div class="hero-monogram" aria-hidden="true">CF</div>
        )
      }
    </div>

    <p class="hero-signal-kicker">First impression</p>
    <p class="hero-signal-label">Professional signal</p>
    <p class="hero-signal-copy">
      Product judgment, hands-on delivery, and content clarity shaped into one visible first impression that feels deliberate instead of generic.
    </p>
  </aside>
</section>
