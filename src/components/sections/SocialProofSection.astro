---
interface Props {
  sectionId: string;
  title: string;
}

const { sectionId, title } = Astro.props;
---

<section class="proof-section" id={sectionId} aria-labelledby={`${sectionId}-title`}>
  <div class="proof-shell editorial-reveal">
    <p class="proof-eyebrow">Next step</p>
    <h2 id={`${sectionId}-title`}>{title}</h2>
    <div class="proof-copy">
      <slot />
    </div>
  </div>
</section>
