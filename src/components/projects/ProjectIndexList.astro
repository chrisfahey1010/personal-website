---
import type { ProjectRecord } from '../../lib/content/get-projects';
import ProjectStructureSummary from './ProjectStructureSummary.astro';

interface Props {
  projects: ProjectRecord[];
}

const { projects } = Astro.props;
---

<ol class="projects-list" aria-label="Project comparison list">
  {
    projects.map((project) => (
      <li>
        <article class="project-card">
          <div class="project-card-heading">
            <p class="project-card-label">Project</p>
            <h2>{project.title}</h2>
          </div>
          <ProjectStructureSummary project={project} variant="preview" />
          <a class="project-card-link" href={project.preview.href}>{project.preview.ctaLabel}</a>
        </article>
      </li>
    ))
  }
</ol>
