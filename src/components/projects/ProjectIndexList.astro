---
import type { ProjectRecord } from '../../lib/content/get-projects';

interface Props {
  projects: ProjectRecord[];
}

const { projects } = Astro.props;
const statusClass = (status: ProjectRecord['status']) => `project-status-${status.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
---

<ol class="projects-list" aria-label="Selected projects">
  {
    projects.map((project) => (
      <li>
        <article class="project-card project-card-horizontal">
          <div class="project-card-main">
            <div class="project-card-heading-row">
              <h3 class="project-card-title">{project.title}</h3>
              <span class:list={['project-status-badge', statusClass(project.status)]}>{project.status}</span>
            </div>
            <p class="project-card-summary">{project.summary}</p>
          </div>
          <div class="project-card-actions" aria-label={`${project.title} links`}>
            <a class="project-card-link project-card-link-secondary" href={project.repositoryUrl} target="_blank" rel="noreferrer">
              GitHub
            </a>
            {
              project.liveUrl && (
                <a class="project-card-link" href={project.liveUrl} target="_blank" rel="noreferrer">
                  Live site
                </a>
              )
            }
          </div>
        </article>
      </li>
    ))
  }
</ol>
