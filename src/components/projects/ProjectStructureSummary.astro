---
import type { ProjectRecord } from '../../lib/content/get-projects';

interface Props {
  project: ProjectRecord;
  variant: 'preview' | 'detail';
}

const { project, variant } = Astro.props as Props;

const highlights = project.detail.proofSections.map((section) => section.title);
const nextStepCopy =
  variant === 'preview'
    ? 'Open the full project page for the full context, decisions, and next steps.'
    : 'Use the links below to continue to projects, resume, or contact.';
---

<dl class:list={['project-structure-list', variant === 'detail' && 'project-structure-list-detail']}>
  <div>
    <dt>Summary</dt>
    <dd>{project.preview.summary}</dd>
  </div>
  <div>
    <dt>Context</dt>
    <dd>{project.preview.context}</dd>
  </div>
  <div>
    <dt>Why it matters</dt>
    <dd>
      <ul class="project-card-cues" aria-label={`${project.title} relevance cues`}>
        {project.preview.relevanceCues.map((cue) => <li>{cue}</li>)}
      </ul>
    </dd>
  </div>
  <div>
    <dt>Highlights</dt>
    <dd>
      <ul class="project-structure-proof-list" aria-label={`${project.title} highlights`}>
        {highlights.map((item) => <li>{item}</li>)}
      </ul>
    </dd>
  </div>
  <div>
    <dt>Next step</dt>
    <dd>{nextStepCopy}</dd>
  </div>
</dl>
